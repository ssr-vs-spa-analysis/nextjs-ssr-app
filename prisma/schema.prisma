generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @db.Uuid
  name        String
  description String
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int
  category    String
  brand       String
  rating      Float
  images      String[]
  attributes  Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([brand])
  @@index([name])
  @@map("products")
}
